<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_assets_server_list" model="ir.ui.view">
        <field name="name">assets.server.list</field>
        <field name="model">assets.server</field>
        <field name="arch" type="xml">
            <list string="Servers">
                <field name="name"/>
                <field name="usage"/>
            </list>
        </field>
    </record>

    <record id="view_assets_server_form" model="ir.ui.view">
        <field name="name">assets.server.form</field>
        <field name="model">assets.server</field>
        <field name="arch" type="xml">
            <form string="Server">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g. Production Web Server"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="usage" placeholder="e.g. Hosting, Database, etc."/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Details" name="details">
                            <field name="details" widget="text" placeholder="Add technical details here..."/>
                            
                          <group>
                                <button name="action_create_history"
                                    string="Add History"
                                    type="object"
                                    class="btn-primary"/>   
                             </group>

                            <field name="history_ids">
                                <list>
                                    <field name="history_type"/>
                                    <field name="notes"/>
                                    <field name="expense_id"/>
                                </list>

                                <form>
                                    <group>
                                        <field name="history_type"/>
                                        <field name="notes"/>
                                        <field name="expense_id"/>
                                        <field name="asset" invisible="1"/>
                                    </group>
                                </form>

                            </field>


                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_assets_server" model="ir.actions.act_window">
        <field name="name">Servers</field>
        <field name="res_model">assets.server</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_assets_server" name="Servers" parent="menu_assets_root" action="action_assets_server"/>
</odoo>
